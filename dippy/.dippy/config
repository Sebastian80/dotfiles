# Dippy config — Sebastian's global rules
#
# Lives at ~/.dippy/config (loaded by Dippy automatically).
# Per-project overrides go in <project>/.dippy
#
# Dippy ships with sensible defaults — see src/dippy/core/allowlists.py.
# This file only ADDS to the defaults.
#
# Syntax:
#   allow <pattern>                  — auto-approve
#   ask   <pattern> "<msg>"          — prompt user (with optional hint)
#   deny  <pattern> "<msg>"          — block (msg goes back to the model so it adapts)
#   deny-redirect <glob> "<msg>"     — block shell redirects writing to matching paths
#
# RULE PRECEDENCE: Dippy uses last-match-wins based on file order. Broader
# allows must come FIRST; specific asks/denies must come AFTER so they
# override for destructive variants.

#---- Allows: non-destructive dev commands ----#
# Git stash: reversible state-save operations. Destructive drop/clear still prompt below.
allow git stash
allow git stash push
allow git stash pop
allow git stash apply
allow git stash show
allow git stash save
# Non-destructive git operations. Destructive variants still prompt below.
allow git add
allow git commit
allow git push
allow git pull
allow git merge
allow git switch
allow git branch
allow git tag
allow git reset
# Formatters, type checkers, test runners — idempotent, read-only, or deterministic
allow ruff
allow pytest
allow pyright
# Jira CLI: read-only ops + comments + transitions are routine, destructive
# variants (DELETE method) still prompt via the ask rule below.
allow jira

#---- Asks: destructive variants prompt for confirmation ----#
# These must come AFTER the broader allows above — last-match-wins.
ask rm -rf                                "rm -rf — confirm? (consider 'gio trash' / 'trash' for recoverable delete)"
ask git add -A                            "git add -A — confirm? (can capture sensitive untracked files; prefer specific paths)"
ask git add .                             "git add . — confirm? (can capture sensitive untracked files; prefer specific paths)"
ask git commit --amend                    "git commit --amend — confirm? (CLAUDE.md prefers new commits over amending)"
ask git push --force                      "git push --force — confirm? (--force-with-lease is safer if remote may have moved)"
ask git rebase -i                         "interactive rebase — confirm?"
ask git stash drop                        "git stash drop — confirm? (permanently discards a stash)"
ask git stash clear                       "git stash clear — confirm? (permanently discards ALL stashes)"
ask git reset --hard                      "git reset --hard — confirm? (discards uncommitted changes in the working tree)"
ask git clean -f                          "git clean -f — confirm? (deletes untracked files)"
ask git clean -fd                         "git clean -fd — confirm? (deletes untracked files AND directories)"
ask git clean -fx                         "git clean -fx — confirm? (deletes untracked AND ignored files)"
ask git checkout --                       "git checkout -- — confirm? (discards local changes to the listed files)"
ask git branch -D                         "git branch -D — confirm? (force-deletes a branch, including unmerged)"
ask git branch -d                         "git branch -d — confirm? (deletes a branch)"
ask jira * -X DELETE *                    "Destructive Jira DELETE — confirm? (-X DELETE removes issues / comments / attachments / links / sprint memberships)"

#---- Denies: hard blocks — must come LAST to win last-match-wins ----#
# Tooling conventions (CLAUDE.md says use uv/pnpm)
deny python3                              "Use 'uv run python' — runs in project venv per CLAUDE.md toolchain rule"
deny python                               "Use 'uv run python' — runs in project venv per CLAUDE.md toolchain rule"
deny pip install                          "Use 'uv add' for project deps, 'uv tool install' for global tools"
deny pip3 install                         "Use 'uv add' for project deps, 'uv tool install' for global tools"
deny git push --no-verify                 "Pre-commit hooks exist for a reason — fix the underlying failure rather than skipping hooks"

#---- Deny-redirect: secrets-write protection (sandbox is off, this is the only writeguard) ----#
deny-redirect **/.env*                    "Never write secrets — ask Sebastian to do it"
deny-redirect ~/.ssh/**                   "Don't touch SSH config — ask Sebastian"
deny-redirect ~/.aws/**                   "Don't touch AWS credentials — ask Sebastian"
deny-redirect ~/.gnupg/**                 "Don't touch GPG keyring — ask Sebastian"
deny-redirect ~/.env.jira                 "Don't touch Jira credentials"
